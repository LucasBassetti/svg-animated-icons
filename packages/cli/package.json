{
  "name": "@svg-animated-icons/cli",
  "version": "0.1.0",
  "description": "Copy animated SVG icon components into your project — shadcn-style.",
  "type": "module",
  "bin": {
    "svg-animated-icons": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "12.1.0",
    "kleur": "4.1.5"
  },
  "devDependencies": {
    "@svg-animated-icons/codegen": "workspace:*",
    "@types/node": "22.10.2",
    "tsup": "8.3.5",
    "typescript": "5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
