{
  "name": "@svg-animated-icons/react",
  "version": "0.1.1",
  "description": "Animated SVG icon React components.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/icons/*.d.ts",
      "default": "./dist/icons/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "19.0.2",
    "react": "19.0.0",
    "tsup": "8.3.5",
    "typescript": "5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
